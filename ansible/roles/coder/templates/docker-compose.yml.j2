services:
  postgres:
    image: {{ coder_postgres_image }}
    restart: unless-stopped
    environment:
      POSTGRES_USER: coder
      POSTGRES_PASSWORD: "{{ coder_pg_password }}"
      POSTGRES_DB: coder
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U coder -d coder"]
      interval: 5s
      timeout: 5s
      retries: 5

  coder:
    image: {{ coder_image }}
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      CODER_PG_CONNECTION_URL: "postgresql://coder:{{ coder_pg_password }}@postgres:5432/coder?sslmode=disable"
{% if coder_domain | default('') | length > 0 %}
      CODER_ACCESS_URL: "https://{{ coder_domain }}"
      CODER_WILDCARD_ACCESS_URL: "*.{{ coder_domain }}"
{% else %}
      CODER_ACCESS_URL: "https://{{ tailscale_fqdn }}"
{% endif %}
      CODER_HTTP_ADDRESS: "0.0.0.0:7080"
      CODER_TELEMETRY_ENABLE: "false"
      # Server-side: used by Coder to auto-generate task names via Anthropic API
      ANTHROPIC_API_KEY: "{{ anthropic_api_key }}"
{% if github_oauth_client_id | default('') | length > 0 %}
      CODER_EXTERNAL_AUTH_0_ID: "github"
      CODER_EXTERNAL_AUTH_0_TYPE: "github"
      CODER_EXTERNAL_AUTH_0_CLIENT_ID: "{{ github_oauth_client_id }}"
      CODER_EXTERNAL_AUTH_0_CLIENT_SECRET: "{{ github_oauth_client_secret }}"
{% endif %}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    group_add:
      - "{{ docker_gid }}"

  caddy:
{% if coder_domain | default('') | length > 0 %}
    build:
      context: .
      dockerfile: Dockerfile.caddy
{% else %}
    image: {{ coder_caddy_image }}
{% endif %}
    restart: unless-stopped
    depends_on:
      - coder
{% if coder_domain | default('') | length > 0 %}
    environment:
      CLOUDFLARE_API_TOKEN: "{{ cloudflare_api_token }}"
{% endif %}
    ports:
      - "0.0.0.0:80:80"
{% if coder_domain | default('') | length > 0 %}
      - "0.0.0.0:443:443"
{% endif %}
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data

volumes:
  postgres_data:
  caddy_data:
