global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'severity']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 1h
  receiver: 'default'
{% if monitoring_alertmanager_webhook_url %}
  routes:
    - match:
        severity: critical
      receiver: 'webhook'
{% endif %}

receivers:
  - name: 'default'
{% if monitoring_alertmanager_webhook_url %}
  - name: 'webhook'
    webhook_configs:
      - url: '{{ monitoring_alertmanager_webhook_url }}'
        send_resolved: true
{% endif %}
