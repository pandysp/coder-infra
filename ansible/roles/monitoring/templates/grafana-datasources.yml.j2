apiVersion: 1
datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: true
    editable: false
{% if monitoring_loki_enabled | default(false) | bool %}
  - name: Loki
    type: loki
    access: proxy
    url: http://loki:3100
    editable: false
{% endif %}
