# Required
hcloud_token       = "<your-hetzner-api-token>"
tailscale_auth_key = "<your-tailscale-auth-key>"
claude_setup_token = "<output-of-claude-setup-token>"
anthropic_api_key  = ""  # optional when using claude setup-token for subscription auth
coder_admin_email  = "your@email.com"

# Optional (these have defaults)
# server_name     = "coder-dev"
# server_type     = "cx33"
# server_location = "fsn1"
# github_oauth_client_id     = ""   # GitHub OAuth App for external auth
# github_oauth_client_secret = ""   # (create at github.com/settings/developers)

# Custom domain (requires Cloudflare for DNS-01 TLS + DNS record management)
# coder_domain         = ""     # e.g. coder.spannagel.dev
# cloudflare_api_token = ""     # Cloudflare API token (DNS zone edit + ACME)
# cloudflare_zone_id   = ""     # Cloudflare zone ID for DNS records
# tailnet_dns_name     = ""     # Tailscale MagicDNS FQDN, e.g. coder-dev.tail1234.ts.net

# Monitoring
# grafana_admin_user     = "admin"
# grafana_admin_password = ""
# alertmanager_webhook_url = ""

# Change this value to re-run Ansible without replacing the server.
# force_reprovision = ""

# Remote state: copy backend.hcl.example to backend.hcl and run `make init`.
# Without backend.hcl, state is stored locally (fine for getting started).
